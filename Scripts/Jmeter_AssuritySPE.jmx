        <hashTree>
          <JSR223Timer guiclass="TestBeanGUI" testclass="JSR223Timer" testname="JSR223 Timer" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// Total target cycle time in milliseconds (e.g., 5000ms = 5 seconds). 10 API/Minute translates to 1 call per 6 seconds.
//Extracting count of test data to calculate threads and TPS
int testDataCount = vars.get(&quot;p_TestDataCount&quot;).toInteger();
float testTPS = vars.get(&quot;p_TPS&quot;).toFloat();


// Users are half the test data count and using little&apos;s law we can derive below to achieve required TPS.
long targetCycleTime = ((testDataCount/2)/testTPS)*1000; 

//log.info(targetCycleTime + &quot;is the value&quot;);

// Retrieve the response time of the previous sampler
long previousResponseTime = ctx.getPreviousResult().getTime();

// Calculate the required dynamic delay
long dynamicDelay = targetCycleTime - previousResponseTime;

// Ensure the delay is never negative if the server response exceeds the target cycle time
if (dynamicDelay &lt; 0) {
    dynamicDelay = 0;
}

// Apply the calculated think time to the Flow Control Action sampler
sampler.setDuration(String.valueOf(dynamicDelay));</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Timer>
          <hashTree/>
        </hashTree>
